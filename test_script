//@version=5
// 5000 AUD 本金，20 倍杠杆模拟
strategy("Shihan's Pure PA + Vol + POC (V16.7)", overlay=true, initial_capital=5000, currency=currency.AUD, default_qty_type=strategy.percent_of_equity, default_qty_value=10, margin_long=5, margin_short=5, max_lines_count=500, max_labels_count=500)

// ==========================================
// 1. 宏观引力场设置 (Macro Filter Settings)
// ==========================================
grp_macro = "--- 机构博弈引力场过滤 ---"
useMacroFilter = input.bool(true, "启用宏微观联动过滤", tooltip="开启后，只有在昨日盘面 POC 附近的信号才会触发下单", group=grp_macro)
proxTicks = input.int(20, "引力场宽度 (Ticks)", tooltip="信号距离昨日 POC 多少 Ticks 内视为有效", group=grp_macro)

grp_sess = "--- 盘面时间设置 (AEDT) ---"
asiaSessTime  = input.session("1000-1800", "亚洲盘", group=grp_sess)
londonSessTime = input.session("1800-2300", "欧洲盘", group=grp_sess)
nySessTime     = input.session("2300-0800", "纽约盘", group=grp_sess)

// ==========================================
// 2. 视觉自定义设置
// ==========================================
grp_visual = "--- 视觉设置 ---"
asiaPocColor = input.color(color.new(color.blue, 40),  "昨日亚洲 POC", group=grp_visual)
lonPocColor  = input.color(color.new(color.purple, 40),"昨日欧洲 POC", group=grp_visual)
nyPocColor   = input.color(color.new(color.orange, 40),"昨日纽约 POC", group=grp_visual)
lineWidth    = input.int(2, "信号划线粗细", minval=1, group=grp_visual)

// ==========================================
// 3. 核心计算：昨日三大盘面 POC
// ==========================================
inAsia   = not na(time(timeframe.period, asiaSessTime, "GMT+11"))
inLondon = not na(time(timeframe.period, londonSessTime, "GMT+11"))
inNY     = not na(time(timeframe.period, nySessTime, "GMT+11"))

var float asiaVWP = 0.0, var float asiaVol = 0.0, var float yestAsiaPOC = na
var float lonVWP  = 0.0, var float lonVol  = 0.0, var float yestLonPOC  = na
var float nyVWP   = 0.0, var float nyVol   = 0.0, var float yestNYPOC   = na

if inAsia and not inAsia[1]
    yestAsiaPOC := asiaVol > 0 ? asiaVWP / asiaVol : yestAsiaPOC
    asiaVWP := 0.0, asiaVol := 0.0
if inAsia
    asiaVWP += hlc3 * volume, asiaVol += volume

if inLondon and not inLondon[1]
    yestLonPOC := lonVol > 0 ? lonVWP / lonVol : yestLonPOC
    lonVWP := 0.0, lonVol := 0.0
if inLondon
    lonVWP += hlc3 * volume, lonVol += volume

if inNY and not inNY[1]
    yestNYPOC := nyVol > 0 ? nyVWP / nyVol : yestNYPOC
    nyVWP := 0.0, nyVol := 0.0
if inNY
    nyVWP += hlc3 * volume, nyVol += volume

plot(yestAsiaPOC, "昨日亚洲 POC", color=asiaPocColor, style=plot.style_linebr, linewidth=1)
plot(yestLonPOC,  "昨日欧洲 POC", color=lonPocColor,  style=plot.style_linebr, linewidth=2)
plot(yestNYPOC,   "昨日纽约 POC", color=nyPocColor,   style=plot.style_linebr, linewidth=2)

// ==========================================
// 4. 信号解剖 (PA + POC 逻辑)
// ==========================================
grp_pa = "--- 策略核心参数 ---"
volMult = input.float(1.2, "放量阈值", step=0.1, group=grp_pa)
swingLen = input.int(20, "波段周期", group=grp_pa)
minRRFilter = input.float(1.2, "最低 RR 拦截", step=0.1, group=grp_pa)

prevOpen = open[1], prevClose = close[1], prevHigh = high[1], prevLow = low[1], prevVol = volume[1]
prevBody = math.abs(prevClose - prevOpen), prevUpper = prevHigh - math.max(prevOpen, prevClose), prevLower = math.min(prevOpen, prevClose) - prevLow
volBase = ta.sma(volume, 50)[1]

isPrevHammer = (prevLower >= prevBody * 2.0) and (prevUpper <= prevBody * 0.8) and (prevBody > 0)
isPrevStar   = (prevUpper >= prevBody * 2.0) and (prevLower <= prevBody * 0.8) and (prevBody > 0)
isPrevPOC = (prevUpper >= prevBody * 1.5) and (prevLower >= prevBody * 1.5) and (math.min(prevUpper, prevLower) / math.max(prevUpper, prevLower, 0.0001) >= 0.6) and (prevBody > 0)

paBuyTrigger  = close > math.max(prevOpen, prevClose)
paSellTrigger = close < math.min(prevOpen, prevClose)

paBuy  = isPrevHammer and paBuyTrigger and (prevVol > volBase * volMult or volume > volBase * volMult)
paSell = isPrevStar and paSellTrigger and (prevVol > volBase * volMult or volume > volBase * volMult)
pocBuy = isPrevPOC and prevVol > volBase * volMult and close > prevHigh
pocSell= isPrevPOC and prevVol > volBase * volMult and close < prevLow

// ==========================================
// 5. 宏微联动过滤核心逻辑
// ==========================================
threshold = proxTicks * syminfo.mintick
isNearAsia = math.abs(close - yestAsiaPOC) <= threshold
isNearLon  = math.abs(close - yestLonPOC)  <= threshold
isNearNY   = math.abs(close - yestNYPOC)   <= threshold
isNearMacro = isNearAsia or isNearLon or isNearNY

// 最终进场条件
validBuy  = (paBuy or pocBuy) and (not useMacroFilter or isNearMacro)
validSell = (paSell or pocSell) and (not useMacroFilter or isNearMacro)

// 视觉差异化：过滤掉的信号打灰色点，通过的打彩色标签
plotshape(not validBuy and (paBuy or pocBuy), title="被过滤的多头信号", style=shape.circle, location=location.belowbar, color=color.new(color.gray, 70), size=size.tiny)
plotshape(not validSell and (paSell or pocSell), title="被过滤的空头信号", style=shape.circle, location=location.abovebar, color=color.new(color.gray, 70), size=size.tiny)

plotshape(validBuy,  title="高价值买入", text="INSTITUTIONAL\nBUY", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.small)
plotshape(validSell, title="高价值卖出", text="INSTITUTIONAL\nSELL", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.small)

// ==========================================
// 6. 执行与告警
// ==========================================
if validBuy
    entryPrice = close
    slPrice = prevLow - 10 * syminfo.mintick
    tpPrice = entryPrice + (entryPrice - slPrice) * 1.5
    if (tpPrice - entryPrice) / (entryPrice - slPrice) >= minRRFilter
        strategy.entry("Long", strategy.long)
        alert("💰 机构博弈多头进场! 入场:" + str.tostring(entryPrice), alert.freq_once_per_bar)

if validSell
    entryPrice = close
    slPrice = prevHigh + 10 * syminfo.mintick
    tpPrice = entryPrice - (slPrice - entryPrice) * 1.5
    if (entryPrice - tpPrice) / (slPrice - entryPrice) >= minRRFilter
        strategy.entry("Short", strategy.short)
        alert("💰 机构博弈空头进场! 入场:" + str.tostring(entryPrice), alert.freq_once_per_bar)
