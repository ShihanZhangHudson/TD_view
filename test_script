//@version=5
indicator("Shihan's Pure PA + Vol + POC (V10.0)", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// 1. 自动止盈止损 (S/R) 设置
// ==========================================
grp_sr = "--- 自动止盈止损与挂单设置 ---"
swingLen = input.int(20, "波段高低点周期 (Swing Length)", group=grp_sr)
slBuffer = input.float(1.0, "止损猎杀缓冲 (美金，如 1.0)", step=0.1, group=grp_sr)

// ==========================================
// 2. 进场突破模式 (Trigger) 设置
// ==========================================
grp_trigger = "--- 进场突破模式 (Trigger) 设置 ---"
modePA  = input.string("宽松模式 (突破实体)", "PA(锤/流星) 突破标准", options=["严格模式 (突破影线极值)", "宽松模式 (突破实体)"], group=grp_trigger)
modePOC = input.string("宽松模式 (突破收盘价)", "POC(平衡) 突破标准", options=["严格模式 (突破影线极值)", "宽松模式 (突破收盘价)"], group=grp_trigger)
isStrictPA  = (modePA == "严格模式 (突破影线极值)")
isStrictPOC = (modePOC == "严格模式 (突破影线极值)")

// ==========================================
// 3. 宏观价值区域 (VAH / VAL) 设置
// ==========================================
grp_va = "--- 宏观价值区域 (Value Area) 设置 ---"
showVA = input.bool(true, "显示日内 VAH / VAL", group=grp_va)
sdMult = input.float(1.0, "价值区标准差乘数", step=0.1, group=grp_va)

// ==========================================
// 4. 形态与成交量参数面板
// ==========================================
grp_hammer = "--- 锤子线 (做多形态) 设置 ---"
hamWickRatio = input.float(2.0, "下影线至少倍数", step=0.5, group=grp_hammer)
hamHeadRatio = input.float(0.8, "上影线最多倍数", step=0.1, group=grp_hammer) 

grp_star = "--- 流星线 (做空形态) 设置 ---"
starWickRatio = input.float(2.0, "上影线至少倍数", step=0.5, group=grp_star)
starHeadRatio = input.float(0.8, "下影线最多倍数", step=0.1, group=grp_star) 

grp_poc = "--- 微观 POC (多空平衡) 设置 ---"
pocWickRatio = input.float(1.5, "上下影线至少倍数", step=0.1, group=grp_poc)
pocSymRatio  = input.float(0.6, "对称度", step=0.1, maxval=1.0, group=grp_poc)

grp_vol = "--- 成交量过滤设置 ---"
volLen  = input.int(50, "成交量均线周期", group=grp_vol)
volMult = input.float(1.5, "放量阈值", step=0.1, group=grp_vol)

// ==========================================
// 5. 核心计算：VAH / VAL 与 价格波段 S/R
// ==========================================
var float sumSrcVol = 0.0, var float sumVol = 0.0, var float sumSrcSrcVol = 0.0
isNewDay = ta.change(time("D")) != 0
if isNewDay
    sumSrcVol := 0.0, sumVol := 0.0, sumSrcSrcVol := 0.0

src = hlc3
sumSrcVol += src * volume, sumVol += volume, sumSrcSrcVol += volume * math.pow(src, 2)
macroPOC = sumSrcVol / sumVol
variance = (sumSrcSrcVol / sumVol) - math.pow(macroPOC, 2)
vwapStdev = math.sqrt(math.max(0, variance))
VAH = macroPOC + (vwapStdev * sdMult)
VAL = macroPOC - (vwapStdev * sdMult)

plot(showVA ? VAH : na, title="VAH", color=color.new(color.red, 30), linewidth=2, style=plot.style_cross)
plot(showVA ? VAL : na, title="VAL", color=color.new(color.green, 30), linewidth=2, style=plot.style_cross)
plot(showVA ? macroPOC : na, title="Macro POC", color=color.new(color.orange, 30), linewidth=1, style=plot.style_circles)

recentSwingHigh = ta.highest(high[1], swingLen)
recentSwingLow  = ta.lowest(low[1], swingLen)

plot(recentSwingHigh, color=color.new(color.red, 80), style=plot.style_circles, linewidth=1, title="Swing High")
plot(recentSwingLow, color=color.new(color.green, 80), style=plot.style_circles, linewidth=1, title="Swing Low")

// ==========================================
// 6. 第一根：特征与成交量解剖 (Setup)
// ==========================================
prevOpen = open[1], prevClose = close[1], prevHigh = high[1], prevLow = low[1], prevVol = volume[1]
prevBody = math.abs(prevClose - prevOpen)
prevUpper = prevHigh - math.max(prevOpen, prevClose)
prevLower = math.min(prevOpen, prevClose) - prevLow

prevVolAvg = ta.sma(volume, volLen)[1]
isPrevVolHigh = prevVol > (prevVolAvg * volMult)

isPrevHammer = (prevLower >= prevBody * hamWickRatio) and (prevUpper <= prevBody * hamHeadRatio) and (prevBody > 0)
isPrevStar   = (prevUpper >= prevBody * starWickRatio) and (prevLower <= prevBody * starHeadRatio) and (prevBody > 0)

symmetry = math.min(prevUpper, prevLower) / math.max(prevUpper, prevLower, 0.0001)
isPrevPOC = (prevUpper >= prevBody * pocWickRatio) and (prevLower >= prevBody * pocWickRatio) and (symmetry >= pocSymRatio) and (prevBody > 0)
isImportantPOC = isPrevPOC and isPrevVolHigh

// ==========================================
// 7. 第二根：量价确认 (Trigger) 与 入场位计算
// ==========================================
currVolAvg = ta.sma(volume, volLen)
isCurrVolHigh = volume > (currVolAvg * volMult)
validVolForPA = isPrevVolHigh or isCurrVolHigh

// 计算突破临界点（这就是最佳挂单价）
paBuyLimit  = isStrictPA ? prevHigh : math.max(prevOpen, prevClose)
paSellLimit = isStrictPA ? prevLow  : math.min(prevOpen, prevClose)
pocBuyLimit = isStrictPOC ? prevHigh : prevClose
pocSellLimit= isStrictPOC ? prevLow  : prevClose

paBuyTrigger  = close > paBuyLimit
paSellTrigger = close < paSellLimit
pocBuyTrigger  = close > pocBuyLimit
pocSellTrigger = close < pocSellLimit

paBuy  = isPrevHammer and paBuyTrigger and validVolForPA
paSell = isPrevStar   and paSellTrigger and validVolForPA
pocBuy  = isImportantPOC and pocBuyTrigger
pocSell = isImportantPOC and pocSellTrigger

// ==========================================
// 8. 综合信号与 自动画线 (SL / ENTRY / TP)
// ==========================================
finalBuy  = paBuy or pocBuy
finalSell = paSell or pocSell

plotshape(isPrevHammer and not finalBuy, title="Wait", style=shape.circle, location=location.belowbar, color=color.new(color.gray, 60), size=size.tiny, offset=-1)
plotshape(isPrevStar and not finalSell,  title="Wait", style=shape.circle, location=location.abovebar, color=color.new(color.gray, 60), size=size.tiny, offset=-1)

plotshape(paBuy,  title="PA BUY",   text="PA BUY",   style=shape.labelup,   location=location.belowbar, color=color.green, size=size.small, textcolor=color.white)
plotshape(paSell, title="PA SELL",  text="PA SELL",  style=shape.labeldown, location=location.abovebar, color=color.red,   size=size.small, textcolor=color.white)

if finalBuy
    entryPrice = paBuy ? paBuyLimit : pocBuyLimit
    slPrice = math.min(prevLow, recentSwingLow) - slBuffer
    tpPrice = recentSwingHigh
    
    // 计算盈亏比 (Risk Reward)
    risk = entryPrice - slPrice
    reward = tpPrice - entryPrice
    rrRatio = risk > 0 ? (reward / risk) : 0
    rrText = " (RR: " + str.tostring(math.round(rrRatio, 1)) + ")"
    
    // 如果 TP 比 Entry 还低（头顶压着阻力），标注警告
    if tpPrice <= entryPrice
        rrText := " (⚠️ 空间不足)"

    line.new(bar_index, tpPrice, bar_index + 8, tpPrice, color=color.green, width=2, style=line.style_dashed)
    label.new(bar_index + 8, tpPrice, "TP: " + str.tostring(math.round(tpPrice, 2)) + rrText, color=color.green, textcolor=color.white, style=label.style_label_left, size=size.small)
    
    line.new(bar_index, entryPrice, bar_index + 8, entryPrice, color=color.yellow, width=2, style=line.style_solid)
    label.new(bar_index + 8, entryPrice, "LIMIT ENTRY: " + str.tostring(math.round(entryPrice, 2)), color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)

    line.new(bar_index, slPrice, bar_index + 8, slPrice, color=color.red, width=2, style=line.style_dashed)
    label.new(bar_index + 8, slPrice, "SL: " + str.tostring(math.round(slPrice, 2)), color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)

if finalSell
    entryPrice = paSell ? paSellLimit : pocSellLimit
    slPrice = math.max(prevHigh, recentSwingHigh) + slBuffer
    tpPrice = recentSwingLow
    
    risk = slPrice - entryPrice
    reward = entryPrice - tpPrice
    rrRatio = risk > 0 ? (reward / risk) : 0
    rrText = " (RR: " + str.tostring(math.round(rrRatio, 1)) + ")"
    
    if tpPrice >= entryPrice
        rrText := " (⚠️ 空间不足)"

    line.new(bar_index, tpPrice, bar_index + 8, tpPrice, color=color.green, width=2, style=line.style_dashed)
    label.new(bar_index + 8, tpPrice, "TP: " + str.tostring(math.round(tpPrice, 2)) + rrText, color=color.green, textcolor=color.white, style=label.style_label_left, size=size.small)
    
    line.new(bar_index, entryPrice, bar_index + 8, entryPrice, color=color.yellow, width=2, style=line.style_solid)
    label.new(bar_index + 8, entryPrice, "LIMIT ENTRY: " + str.tostring(math.round(entryPrice, 2)), color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)

    line.new(bar_index, slPrice, bar_index + 8, slPrice, color=color.red, width=2, style=line.style_dashed)
    label.new(bar_index + 8, slPrice, "SL: " + str.tostring(math.round(slPrice, 2)), color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)

alertcondition(finalBuy,  "Buy Alert",  "做多确认！看黄线挂单，绿线止盈，红线止损。")
alertcondition(finalSell, "Sell Alert", "做空确认！看黄线挂单，绿线止盈，红线止损。")
