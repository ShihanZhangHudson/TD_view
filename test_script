//@version=5
indicator("Shihan's Pure PA + Vol + POC (V14.0)", overlay=true, max_lines_count=500, max_labels_count=500)

// ==========================================
// 1. 核心交易模式选择 (Master Switch)
// ==========================================
grp_mode = "--- 核心交易模式选择 ---"
tradeMode = input.string("3. PA + POC (双模式共存)", "请选择启用的信号模式", options=["1. PA 模式 (锤子/流星)", "2. POC 模式 (多空平衡)", "3. PA + POC (双模式共存)"], group=grp_mode)
enablePA  = (tradeMode == "1. PA 模式 (锤子/流星)") or (tradeMode == "3. PA + POC (双模式共存)")
enablePOC = (tradeMode == "2. POC 模式 (多空平衡)") or (tradeMode == "3. PA + POC (双模式共存)")

// ==========================================
// 2. 自动止盈止损与挂单设置 (全新升级)
// ==========================================
grp_sr = "--- 自动止盈止损与 RR 设置 ---"
slMode = input.string("1. 紧贴形态极值 (最优盈亏比)", "止损防线选择", options=["1. 紧贴形态极值 (最优盈亏比)", "2. 宽松波段极值 (防守空间更大)"], group=grp_sr)
// 修复：改用 Ticks(跳动点) 而非绝对金额，兼容外汇和加密货币
slTicks = input.int(10, "止损猎杀缓冲 (Ticks/跳动点数)", group=grp_sr) 

targetMode = input.string("1. 波段高低点 (S/R)", "止盈目标模式", options=["1. 波段高低点 (S/R)", "2. 固定自定义盈亏比 (Fixed RR)"], group=grp_sr)
customRR = input.float(1.5, "自定义/保底 盈亏比 (RR)", step=0.1, group=grp_sr)

swingLen = input.int(20, "波段高低点周期 (Swing Length)", group=grp_sr)

// ==========================================
// 3. 进场突破模式 (Trigger) 设置
// ==========================================
grp_trigger = "--- 进场突破模式 (Trigger) 设置 ---"
modePA  = input.string("宽松模式 (突破实体)", "PA(锤/流星) 突破标准", options=["严格模式 (突破影线极值)", "宽松模式 (突破实体)"], group=grp_trigger)
modePOC = input.string("严格模式 (突破影线极值)", "POC(平衡) 突破标准", options=["严格模式 (突破影线极值)", "宽松模式 (突破收盘价)"], group=grp_trigger)
isStrictPA  = (modePA == "严格模式 (突破影线极值)")
isStrictPOC = (modePOC == "严格模式 (突破影线极值)")

// ==========================================
// 4. 宏观价值区域 (VAH / VAL) 设置
// ==========================================
grp_va = "--- 宏观价值区域 (Value Area) 设置 ---"
showVA = input.bool(true, "显示日内 VAH / VAL", group=grp_va)
sdMult = input.float(1.0, "价值区标准差乘数", step=0.1, group=grp_va)

// ==========================================
// 5. 形态与成交量参数面板
// ==========================================
grp_hammer = "--- 锤子线 (做多形态) 设置 ---"
hamWickRatio = input.float(2.0, "下影线至少倍数", step=0.5, group=grp_hammer)
hamHeadRatio = input.float(0.8, "上影线最多倍数", step=0.1, group=grp_hammer) 

grp_star = "--- 流星线 (做空形态) 设置 ---"
starWickRatio = input.float(2.0, "上影线至少倍数", step=0.5, group=grp_star)
starHeadRatio = input.float(0.8, "下影线最多倍数", step=0.1, group=grp_star) 

grp_poc = "--- 微观 POC (多空平衡) 设置 ---"
pocWickRatio = input.float(1.5, "上下影线至少倍数", step=0.1, group=grp_poc)
pocSymRatio  = input.float(0.6, "对称度", step=0.1, maxval=1.0, group=grp_poc)

grp_vol = "--- 成交量过滤设置 ---"
volLen  = input.int(50, "成交量均线周期", group=grp_vol)
volMult = input.float(1.5, "放量阈值", step=0.1, group=grp_vol)

// ==========================================
// 6. 核心计算：VAH / VAL 与 价格波段 S/R 
// ==========================================
var float sumSrcVol = 0.0, var float sumVol = 0.0, var float sumSrcSrcVol = 0.0
isNewDay = ta.change(time("D")) != 0
if isNewDay
    sumSrcVol := 0.0, sumVol := 0.0, sumSrcSrcVol := 0.0

src = hlc3
sumSrcVol += src * volume, sumVol += volume, sumSrcSrcVol += volume * math.pow(src, 2)
macroPOC = sumVol > 0 ? (sumSrcVol / sumVol) : src
variance = sumVol > 0 ? ((sumSrcSrcVol / sumVol) - math.pow(macroPOC, 2)) : 0
vwapStdev = math.sqrt(math.max(0, variance))
VAH = macroPOC + (vwapStdev * sdMult)
VAL = macroPOC - (vwapStdev * sdMult)

plot(showVA ? VAH : na, title="VAH", color=color.new(color.red, 30), linewidth=2, style=plot.style_cross)
plot(showVA ? VAL : na, title="VAL", color=color.new(color.green, 30), linewidth=2, style=plot.style_cross)
plot(showVA ? macroPOC : na, title="Macro POC", color=color.new(color.orange, 30), linewidth=1, style=plot.style_circles)

recentSwingHigh = ta.highest(high[1], swingLen)
recentSwingLow  = ta.lowest(low[1], swingLen)

plot(recentSwingHigh, color=color.new(color.red, 80), style=plot.style_circles, linewidth=1, title="Swing High")
plot(recentSwingLow, color=color.new(color.green, 80), style=plot.style_circles, linewidth=1, title="Swing Low")

// ==========================================
// 7. 第一根：特征与成交量解剖 (Setup)
// ==========================================
prevOpen = open[1], prevClose = close[1], prevHigh = high[1], prevLow = low[1], prevVol = volume[1]
prevBody = math.abs(prevClose - prevOpen)
prevUpper = prevHigh - math.max(prevOpen, prevClose)
prevLower = math.min(prevOpen, prevClose) - prevLow

volBase = ta.sma(volume, volLen)[1] 
isPrevVolHigh = prevVol > (volBase * volMult)

isPrevHammer = (prevLower >= prevBody * hamWickRatio) and (prevUpper <= prevBody * hamHeadRatio) and (prevBody > 0)
isPrevStar   = (prevUpper >= prevBody * starWickRatio) and (prevLower <= prevBody * starHeadRatio) and (prevBody > 0)

symmetry = math.min(prevUpper, prevLower) / math.max(prevUpper, prevLower, 0.0001)
isPrevPOC = (prevUpper >= prevBody * pocWickRatio) and (prevLower >= prevBody * pocWickRatio) and (symmetry >= pocSymRatio) and (prevBody > 0)
isImportantPOC = isPrevPOC and isPrevVolHigh

// ==========================================
// 8. 第二根：量价确认 (Trigger) 
// ==========================================
isCurrVolHigh = volume > (volBase * volMult) 
validVolForPA = isPrevVolHigh or isCurrVolHigh

paBuyLimit  = isStrictPA ? prevHigh : math.max(prevOpen, prevClose)
paSellLimit = isStrictPA ? prevLow  : math.min(prevOpen, prevClose)
pocBuyLimit = isStrictPOC ? prevHigh : prevClose
pocSellLimit= isStrictPOC ? prevLow  : prevClose

paBuyTrigger  = close > paBuyLimit
paSellTrigger = close < paSellLimit
pocBuyTrigger  = close > pocBuyLimit
pocSellTrigger = close < pocSellLimit

paBuy  = enablePA  and isPrevHammer and paBuyTrigger and validVolForPA
paSell = enablePA  and isPrevStar   and paSellTrigger and validVolForPA
pocBuy = enablePOC and isImportantPOC and pocBuyTrigger
pocSell= enablePOC and isImportantPOC and pocSellTrigger

// ==========================================
// 9. 综合信号与 可视化画线 (跨品种精度修复)
// ==========================================
finalBuy  = paBuy or pocBuy
finalSell = paSell or pocSell

plotshape(enablePA  and isPrevHammer and not finalBuy, title="Wait PA", style=shape.circle, location=location.belowbar, color=color.new(color.gray, 60), size=size.tiny, offset=-1)
plotshape(enablePA  and isPrevStar   and not finalSell, title="Wait PA", style=shape.circle, location=location.abovebar, color=color.new(color.gray, 60), size=size.tiny, offset=-1)
plotshape(enablePOC and isImportantPOC and not (pocBuy or pocSell), title="Wait POC", style=shape.diamond, location=location.abovebar, color=color.new(color.blue, 50), size=size.tiny, offset=-1)

plotshape(paBuy,  title="PA BUY",   text="PA BUY",   style=shape.labelup,   location=location.belowbar, color=color.green, size=size.small, textcolor=color.white)
plotshape(paSell, title="PA SELL",  text="PA SELL",  style=shape.labeldown, location=location.abovebar, color=color.red,   size=size.small, textcolor=color.white)
plotshape(pocBuy, title="POC BUY",  text="POC UP",   style=shape.labelup,   location=location.belowbar, color=color.teal,  size=size.small, textcolor=color.white)
plotshape(pocSell,title="POC SELL", text="POC DOWN", style=shape.labeldown, location=location.abovebar, color=color.maroon,size=size.small, textcolor=color.white)

lineLen = 15
actualBuffer = slTicks * syminfo.mintick // 将设定的跳动点数转换为该品种的真实价格差

if finalBuy
    entryPrice = paBuy ? paBuyLimit : pocBuyLimit
    tradeTag   = paBuy ? "[PA BUY]" : "[POC BUY]"
    
    slPrice = (slMode == "1. 紧贴形态极值 (最优盈亏比)") ? (prevLow - actualBuffer) : (recentSwingLow - actualBuffer)
    
    // 止盈模式判断逻辑
    tpPrice = 0.0
    if targetMode == "2. 固定自定义盈亏比 (Fixed RR)"
        tpPrice := entryPrice + (entryPrice - slPrice) * customRR
    else
        tpPrice := recentSwingHigh
        if tpPrice <= entryPrice
            tpPrice := entryPrice + (entryPrice - slPrice) * customRR
        
    risk = entryPrice - slPrice
    reward = tpPrice - entryPrice
    rrRatio = risk > 0 ? (reward / risk) : 0
    rrText = (targetMode == "2. 固定自定义盈亏比 (Fixed RR)" or tpPrice != recentSwingHigh) ? " (固定 RR: " + str.tostring(rrRatio, "#.#") + ")" : " (RR: " + str.tostring(rrRatio, "#.#") + ")"

    // 修复：读取品种原生精度 format.mintick
    line.new(bar_index, tpPrice, bar_index + lineLen, tpPrice, color=color.green, width=2, style=line.style_dashed)
    label.new(bar_index + lineLen, tpPrice, "TP: " + str.tostring(tpPrice, format.mintick) + rrText, color=color.green, textcolor=color.white, style=label.style_label_left, size=size.small)
    
    line.new(bar_index, entryPrice, bar_index + lineLen, entryPrice, color=color.yellow, width=2, style=line.style_solid)
    label.new(bar_index + lineLen, entryPrice, tradeTag + " LIMIT: " + str.tostring(entryPrice, format.mintick), color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)

    line.new(bar_index, slPrice, bar_index + lineLen, slPrice, color=color.red, width=3, style=line.style_dashed)
    label.new(bar_index + lineLen, slPrice, "SL: " + str.tostring(slPrice, format.mintick), color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)

if finalSell
    entryPrice = paSell ? paSellLimit : pocSellLimit
    tradeTag   = paSell ? "[PA SELL]" : "[POC SELL]"

    slPrice = (slMode == "1. 紧贴形态极值 (最优盈亏比)") ? (prevHigh + actualBuffer) : (recentSwingHigh + actualBuffer)
    
    // 止盈模式判断逻辑
    tpPrice = 0.0
    if targetMode == "2. 固定自定义盈亏比 (Fixed RR)"
        tpPrice := entryPrice - (slPrice - entryPrice) * customRR
    else
        tpPrice := recentSwingLow
        if tpPrice >= entryPrice
            tpPrice := entryPrice - (slPrice - entryPrice) * customRR
        
    risk = slPrice - entryPrice
    reward = entryPrice - tpPrice
    rrRatio = risk > 0 ? (reward / risk) : 0
    rrText = (targetMode == "2. 固定自定义盈亏比 (Fixed RR)" or tpPrice != recentSwingLow) ? " (固定 RR: " + str.tostring(rrRatio, "#.#") + ")" : " (RR: " + str.tostring(rrRatio, "#.#") + ")"

    // 修复：读取品种原生精度 format.mintick
    line.new(bar_index, tpPrice, bar_index + lineLen, tpPrice, color=color.green, width=2, style=line.style_dashed)
    label.new(bar_index + lineLen, tpPrice, "TP: " + str.tostring(tpPrice, format.mintick) + rrText, color=color.green, textcolor=color.white, style=label.style_label_left, size=size.small)
    
    line.new(bar_index, entryPrice, bar_index + lineLen, entryPrice, color=color.yellow, width=2, style=line.style_solid)
    label.new(bar_index + lineLen, entryPrice, tradeTag + " LIMIT: " + str.tostring(entryPrice, format.mintick), color=color.yellow, textcolor=color.black, style=label.style_label_left, size=size.small)

    line.new(bar_index, slPrice, bar_index + lineLen, slPrice, color=color.red, width=3, style=line.style_dashed)
    label.new(bar_index + lineLen, slPrice, "SL: " + str.tostring(slPrice, format.mintick), color=color.red, textcolor=color.white, style=label.style_label_left, size=size.small)

// ==========================================
// 10. 独立专属警报系统
// ==========================================
alertcondition(paBuy,  "PA 做多",  "锤子线破位确认！寻找黄线挂单。")
alertcondition(paSell, "PA 做空",  "流星线破位确认！寻找黄线挂单。")
alertcondition(pocBuy, "POC 向上突破", "多空平衡打破！强逼空行情准备入场！")
alertcondition(pocSell,"POC 向下突破", "多空平衡打破！强逼多行情准备入场！")
